PORT=3000

# Set to 'true' in production to actually send FCM push notifications
SEND_FCM=false

# Admin dashboard access token
# Generate: node -e "import('crypto').then(c=>console.log(c.randomBytes(32).toString('hex')))"
ADMIN_TOKEN=your_random_token_here

# JWT signing secret for DeepSeek proxy tokens (15-min lifetime)
# Generate: node -e "import('crypto').then(c=>console.log(c.randomBytes(48).toString('hex')))"
JWT_SECRET=your_jwt_secret_here

# DeepSeek API key — injected server-side, never exposed to clients
DEEPSEEK_API_KEY=your_deepseek_api_key_here
